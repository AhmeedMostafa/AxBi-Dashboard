# ─────────────────────────────────────────────────────────────────────────────
# AxBi environment template.
#
# QUICK START (recommended):
#   1. Copy this file to `.env` in the repo root:
#        cp .env.example .env
#   2. Fill in the values below.
#   3. Run:
#        docker compose up --build
#   4. Open http://localhost:8080
#
# ALTERNATIVE — inline keys in docker-compose.yml:
#   Edit the `x-app-config` block at the top of docker-compose.yml instead of
#   using this file. Do not commit real secrets to git.
#
# LEGACY — split env files (still supported):
#   backend/.env  +  frontend/.env
#
# `.env` is gitignored — NEVER commit real keys. This repo is public.
# Docker Compose auto-loads a root `.env` for ${VAR} substitution.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ──────────────────────────────────────────────────────────────────
# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# ── Supabase (backend / server-side) ─────────────────────────────────────────
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Service role key (SECRET — full DB access). Supabase dashboard →
# Project Settings → API → service_role key.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Optional: JWT secret for fast local token verification (Project Settings → API →
# JWT Settings). If omitted, tokens are verified via the Supabase auth API instead.
SUPABASE_JWT_SECRET=

# ── Supabase (frontend / build-time, inlined into the SPA bundle) ─────────────
# Same project URL as above.
VITE_SUPABASE_URL=https://your-project.supabase.co
# Anon/public key (safe to expose in the browser). Dashboard → API → anon key.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google Gemini (AI pipeline: steps 5/7/8, chat, segmentation) ─────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Optional: voice / TTS (leave blank to disable those features) ─────────────
# GOOGLE_TTS_API_KEY=
# GEMINI_LIVE_MODEL=

# ── Optional: Docker smoke test (backend/scripts/docker_smoke_test.py) ───────
# E2E_TEST_EMAIL=your-test-user@example.com
# E2E_TEST_PASSWORD=your-test-password

# Note: CELERY_BROKER_URL / CELERY_RESULT_BACKEND are set by docker-compose
# (redis://redis:6379/0) — no need to define them here.
